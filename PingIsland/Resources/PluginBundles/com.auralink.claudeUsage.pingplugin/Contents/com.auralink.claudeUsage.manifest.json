{
  "id": "com.auralink.claudeUsage",
  "name": "Claude 用量",
  "version": "1.0.0",
  "protocolVersion": "2.0",
  "author": "Auralink",
  "category": "monitoring",
  "executable": "PingIslandPlugin",
  "slots": ["compact", "expanded"],
  "builtIn": true,
  "permissions": ["network", "keychain"],
  "description": "监控 Claude 用量与配额（5小时窗口 / 7日）",
  "icon": { "sfSymbol": "brain.head.profile", "color": "#E8834A" },
  "config": [
    {
      "key": "claudeSessionKey",
      "label": "Claude Session Key",
      "type": "secret",
      "hint": "claude.ai → F12 → Cookies → sessionKey",
      "required": false
    },
    {
      "key": "refreshInterval",
      "label": "刷新间隔",
      "type": "number",
      "default": "300",
      "min": 60,
      "max": 3600,
      "step": 60,
      "unit": "秒"
    }
  ]
}
