#!/usr/bin/env python3
"""
ClaudePlugin — Island Plugin Protocol executable.
Receives hookEvent messages from PingIsland and pushes compact/notify updates.
"""
import sys
import json

active_sessions = {}  # sessionId -> {"provider": str, "cwd": str}

def send(msg):
    sys.stdout.write(json.dumps(msg, ensure_ascii=False) + "\n")
    sys.stdout.flush()

def send_compact():
    count = len(active_sessions)
    if count > 0:
        icon = "brain.head.profile" if count == 1 else "cpu"
        content = {
            "icon": {"type": "sf", "name": icon},
            "label": str(count),
            "tint": "default"
        }
    else:
        content = None

    send({
        "jsonrpc": "2.0",
        "method": "island/compact",
        "params": {"position": "right", "content": content}
    })

def handle_hook_event(params):
    session_id = params.get("sessionId", "")
    phase = params.get("phase", "idle")
    provider = params.get("provider", "claude")
    cwd = params.get("cwd", "")

    was_active = session_id in active_sessions

    if phase == "ended":
        if was_active:
            session_info = active_sessions.pop(session_id, {})
            send_compact()
            project = (session_info.get("cwd", "") or "").rstrip("/").split("/")[-1] or "项目"
            send({
                "jsonrpc": "2.0",
                "method": "island/notify",
                "params": {
                    "icon": {"type": "sf", "name": "checkmark.circle.fill"},
                    "title": "会话已完成",
                    "subtitle": project,
                    "duration": 4.0
                }
            })
    else:
        if not was_active:
            active_sessions[session_id] = {"provider": provider, "cwd": cwd}
            send_compact()

def main():
    for raw in sys.stdin:
        line = raw.strip()
        if not line:
            continue
        try:
            msg = json.loads(line)
        except json.JSONDecodeError:
            continue

        method = msg.get("method", "")
        params = msg.get("params") or {}
        req_id = msg.get("id")

        if method == "initialize":
            send({"jsonrpc": "2.0", "id": req_id or 1,
                  "result": {"name": "Claude 会话", "ready": True}})
            send_compact()
        elif method == "hookEvent":
            handle_hook_event(params)
        elif method == "shutdown":
            sys.exit(0)

if __name__ == "__main__":
    main()
